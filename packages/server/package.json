{
  "name": "@beam/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Beam signaling server — Fastify + WebSocket, Redis-backed ephemeral rooms. Never stores files or keys.",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@beam/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "ioredis-mock": "^8.9.0",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
