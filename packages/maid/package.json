{
  "name": "@beam/maid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Blind encrypted temporary storage service for Drop.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./config": "./src/config.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@beam/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
