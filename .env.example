# ─────────────────────────────────────────────────────────────
# Drop environment configuration
# Copy to `.env` and adjust. The server reads these at boot.
# The client reads VITE_* vars from the repo root (vite envDir).
# ─────────────────────────────────────────────────────────────

# ── Server (packages/server) ──────────────────────────────────
PORT=8787
HOST=0.0.0.0

# Redis stores ONLY ephemeral room/presence state (never files or keys).
REDIS_URL=redis://localhost:6379

# Ephemeral room time-to-live, in seconds (rooms auto-expire).
ROOM_TTL_SECONDS=3600

# Comma-separated CORS origins allowed to reach the signaling server.
CORS_ORIGINS=http://localhost:5173

# ── ICE / NAT traversal ───────────────────────────────────────
# STUN is always used (public servers by default).
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN is OPTIONAL. Leave blank to run STUN-only.
# When all three are set, the server hands TURN creds to clients,
# which makes transfers work behind symmetric NAT / CGNAT.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Client (packages/client) ──────────────────────────────────
# Base URL of the signaling server, as reached from the browser.
VITE_SIGNALING_URL=http://localhost:8787
