# Public DNS name whose A record points to the VM's reserved public IP.
MAID_HOST=maid.example.com

# Browser origin allowed to call the maid.
CORS_ORIGINS=https://drop.example.com

# Generate with: openssl rand -base64 32
MAID_ACCESS_TOKEN=replace-with-at-least-24-random-characters

# Conservative payload cap for a 150 GB data volume.
MAX_PARK_BYTES=125000000000
MIN_FREE_BYTES=5000000000

# Three days by default; thirty days maximum.
DEFAULT_TTL_SECONDS=259200
MAX_TTL_SECONDS=2592000
